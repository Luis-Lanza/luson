# Server Configuration
PORT=8080

# Database Configuration (Go backend uses this)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/battery_pos?sslmode=disable

# PostgreSQL Configuration (Docker uses these)
POSTGRES_DB=battery_pos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# BCRYPT Configuration (for offline auth)
BCRYPT_COST=12
